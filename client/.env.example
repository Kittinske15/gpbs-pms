# Client Environment Variables

# Port for development server (default: 3000)
PORT=3001

# API Base URL
# Leave blank for auto-detection (localhost in dev, ibsdo.com otherwise)
REACT_APP_API_URL=

# Example values:
# Development: REACT_APP_API_URL=http://localhost:3333
# Production: REACT_APP_API_URL=http://ibsdo.com:3333