{
  "name": "true-vision-warroom-server",
  "version": "1.0.0",
  "description": "Express server for True Vision Warroom",
  "main": "app.js",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "concurrently": "^7.4.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.1",
    "jsonwebtoken": "^8.5.1",
    "multer": "^2.1.1",
    "mysql2": "^2.3.3",
    "nodemailer": "^6.10.1",
    "nodemon": "^2.0.20"
  },
  "scripts": {
    "start": "node app.js",
    "start-all": "node -e \"require('child_process').spawn('node',['app.js'],{stdio:'inherit'}); require('child_process').spawn('npm',['start'],{cwd:'../client',stdio:'inherit',shell:true});\"",
    "dev": "nodemon app.js",
    "dev-full": "node -e \"require('child_process').spawn('npx',['nodemon','app.js'],{stdio:'inherit',shell:true}); require('child_process').spawn('npm',['start'],{cwd:'../client',stdio:'inherit',shell:true});\""
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
