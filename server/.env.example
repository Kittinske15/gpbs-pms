# GPBS PMS — server environment template
# Copy this to `.env` on the server and fill in real values. Never commit `.env`.

# --- Node / Express ---
PORT=8081
NODE_ENV=production

# --- Database (create a fresh DB for GPBS, do NOT reuse tvs_db_dup) ---
DB_HOST=localhost
DB_USER=ibsdo
DB_PASSWORD=CHANGE_ME
DB_NAME=gpbs_db
DB_PORT=3306

# --- JWT / Auth ---
# Generate a long random string, e.g.: openssl rand -hex 48
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING

# --- Admin reset key (used by /admin-reset-password etc.) ---
ADMIN_RESET_KEY=CHANGE_ME_ADMIN_KEY

# --- SMTP (optional, for OTP / forgot-password emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="GPBS PMS <noreply@example.com>"
